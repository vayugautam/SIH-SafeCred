# Core Infrastructure
ENVIRONMENT=development
PROJECT_NAME="SafeCred API"

# Security & Secrets
FERNET_KEY=YOUR_BASE64_FERNET_KEY_HERE
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_in_prod

# HashiCorp Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root_dev_token

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://safecred_user:safecred_pass@postgres:5432/safecred_db
POSTGRES_USER=safecred_user
POSTGRES_PASSWORD=safecred_pass
POSTGRES_DB=safecred_db

# MongoDB
MONGO_URI=mongodb://mongo_user:mongo_pass@mongodb:27017/safecred?authSource=admin
MONGO_INITDB_ROOT_USERNAME=mongo_user
MONGO_INITDB_ROOT_PASSWORD=mongo_pass

# Redis & Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# Kafka
KAFKA_BROKER_URL=kafka:9092

# MinIO (S3 Compatible Storage)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret_password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=consumption-docs

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minio_admin
AWS_SECRET_ACCESS_KEY=minio_secret_password

# Sentry (Optional)
SENTRY_DSN=
